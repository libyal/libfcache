.Dd June 11, 2026
.Dt LIBFCACHE 3
.Os
.Sh NAME
.Nm libfcache.h
.Nd Library to provide generic file data cache functions
.Sh SYNOPSIS
.In libfcache.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libfcache_get_version
.Fa "void"
.Fc
.fi
.Pp
Error functions
.nf
.Ft void
.Fo libfcache_error_free
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_error_fprint
.Fa "libfcache_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_error_sprint
.Fa "libfcache_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_error_backtrace_fprint
.Fa "libfcache_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_error_backtrace_sprint
.Fa "libfcache_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.Pp
Cache functions
.nf
.Ft int
.Fo libfcache_cache_initialize
.Fa "libfcache_cache_t **cache"
.Fa "int maximum_cache_entries"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_free
.Fa "libfcache_cache_t **cache"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_empty
.Fa "libfcache_cache_t *cache"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_clone
.Fa "libfcache_cache_t **destination_cache"
.Fa "libfcache_cache_t *source_cache"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_get_number_of_entries
.Fa "libfcache_cache_t *cache"
.Fa "int *number_of_entries"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_get_number_of_cache_values
.Fa "libfcache_cache_t *cache"
.Fa "int *number_of_values"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_clear_value_by_index
.Fa "libfcache_cache_t *cache"
.Fa "int cache_entry_index"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_get_value_by_identifier
.Fa "libfcache_cache_t *cache"
.Fa "int file_index"
.Fa "off64_t offset"
.Fa "int64_t timestamp"
.Fa "libfcache_cache_value_t **cache_value"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_get_value_by_index
.Fa "libfcache_cache_t *cache"
.Fa "int cache_entry_index"
.Fa "libfcache_cache_value_t **cache_value"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_set_value_by_identifier
.Fa "libfcache_cache_t *cache"
.Fa "int file_index"
.Fa "off64_t offset"
.Fa "int64_t timestamp"
.Fa "intptr_t *value"
.Fa "int (*value_free_function)( intptr_t **value, \
libfcache_error_t **error )"
.Fa "uint8_t flags"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_set_value_by_index
.Fa "libfcache_cache_t *cache"
.Fa "int cache_entry_index"
.Fa "int file_index"
.Fa "off64_t offset"
.Fa "int64_t timestamp"
.Fa "intptr_t *value"
.Fa "int (*value_free_function)( intptr_t **value, \
libfcache_error_t **error )"
.Fa "uint8_t flags"
.Fa "libfcache_error_t **error"
.Fc
.fi
.Pp
Cache value functions
.nf
.Ft int
.Fo libfcache_cache_value_free
.Fa "libfcache_cache_value_t **cache_value"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_value_clear
.Fa "libfcache_cache_value_t *cache_value"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_value_get_identifier
.Fa "libfcache_cache_value_t *cache_value"
.Fa "int *file_index"
.Fa "off64_t *offset"
.Fa "int64_t *timestamp"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_value_set_identifier
.Fa "libfcache_cache_value_t *cache_value"
.Fa "int file_index"
.Fa "off64_t offset"
.Fa "int64_t timestamp"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_value_get_value
.Fa "libfcache_cache_value_t *cache_value"
.Fa "intptr_t **value"
.Fa "libfcache_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libfcache_cache_value_set_value
.Fa "libfcache_cache_value_t *cache_value"
.Fa "intptr_t *value"
.Fa "int (*value_free_function)( intptr_t **value, \
libfcache_error_t **error )"
.Fa "uint8_t flags"
.Fa "libfcache_error_t **error"
.Fc
.fi
.Pp
Date time functions
.nf
.Ft int
.Fo libfcache_date_time_get_timestamp
.Fa "int64_t *timestamp"
.Fa "libfcache_error_t **error"
.Fc
.fi
.Sh DESCRIPTION
The
.Fn libfcache_get_version
function is used to retrieve the library version.
.Sh RETURN VALUES
Most of the functions return NULL or \-1 on error, dependent on the return \
type.
For the actual return values see
.In libfcache.h .
